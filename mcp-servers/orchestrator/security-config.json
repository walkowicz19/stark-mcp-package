{
  "sensitiveFilePatterns": [
    ".env",
    ".env.*",
    "*.key",
    "*.pem",
    "*.p12",
    "*.pfx",
    "credentials.*",
    "secrets.*",
    "config/database.*",
    "*.crt",
    "*.cer",
    "id_rsa",
    "id_dsa",
    "*.ppk",
    "*.keystore",
    "*.jks",
    "*.password",
    "*.pwd",
    ".aws/credentials",
    ".ssh/id_*",
    "*.token",
    "**/configs/*.json",
    "**/*config*.json"
  ],
  "dangerousOperations": [
    "delete",
    "unlink",
    "rm",
    "rmdir",
    "remove",
    "destroy",
    "truncate",
    "drop",
    "wipe"
  ],
  "systemPaths": [
    "/etc",
    "/sys",
    "/proc",
    "/dev",
    "/boot",
    "/root",
    "C:\\Windows",
    "C:\\Program Files",
    "C:\\Program Files (x86)",
    "/usr/bin",
    "/usr/sbin",
    "/bin",
    "/sbin"
  ],
  "workspaceOnly": true,
  "requirePasswordFor": [
    "out-of-workspace",
    "sensitive-files",
    "dangerous-operations"
  ],
  "autoRouting": {
    "enabled": true,
    "confidenceThreshold": 0.7
  },
  "rateLimiting": {
    "maxAttempts": 5,
    "windowMs": 900000,
    "blockDurationMs": 3600000
  },
  "credentialRedaction": {
    "enabled": true,
    "patterns": [
      "password",
      "token",
      "api_key",
      "apiKey",
      "secret",
      "SECRET",
      "PASSWORD",
      "TOKEN",
      "SYTRA_ADMIN_PASSWORD",
      "AWS_SECRET_ACCESS_KEY",
      "AWS_ACCESS_KEY_ID",
      "AWS_SESSION_TOKEN",
      "private_key",
      "privateKey",
      "bearer",
      "jwt",
      "connectionString",
      "connection_string",
      "DATABASE_URL"
    ],
    "filePatterns": [
      "**/configs/*.json",
      "**/*config*.json",
      "**/.env*",
      "**/credentials*",
      "**/*.pem",
      "**/*.key",
      "**/*.p12",
      "**/*.pfx",
      "**/.aws/credentials",
      "**/.ssh/id_*"
    ]
  }
}